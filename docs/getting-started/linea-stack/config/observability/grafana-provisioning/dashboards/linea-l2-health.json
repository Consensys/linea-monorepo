{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "title": "Linea L2 health",
  "uid": "linea-l2-health",
  "tags": ["linea", "l2"],
  "timezone": "",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "L2 block height",
      "description": "Current block height as reported by the sequencer and the RPC follower. Divergence indicates the follower is lagging.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "ethereum_blockchain_chain_head_block_number{job=\"sequencer\"}",
          "legendFormat": "sequencer",
          "refId": "A"
        },
        {
          "expr": "ethereum_blockchain_chain_head_block_number{job=\"l2-node-besu\"}",
          "legendFormat": "l2-node-besu",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "L2 tx throughput (per 5 min, rate)",
      "description": "Rate of transactions processed by the sequencer.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(ethereum_blockchain_transactions_total{job=\"sequencer\"}[5m])",
          "legendFormat": "tx/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "L1 submission lag (seconds since last finalisation)",
      "description": "Wall-clock seconds since the coordinator last finalised an aggregation on L1. Sustained high values suggest a stuck submission.",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 600 },
              { "color": "red", "value": 1800 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "value" },
      "targets": [
        {
          "expr": "time() - coordinator_l1_finalization_last_success_timestamp_seconds",
          "legendFormat": "lag",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Coordinator conflation queue depth",
      "description": "Number of conflations queued ahead of the prover. Sustained growth indicates the prover is the bottleneck.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "coordinator_conflation_queue_size",
          "legendFormat": "queue depth",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Prover throughput (jobs / 5 min, rate)",
      "description": "Rate of prover jobs completed. Zero means the prover is idle or absent (expected when running `stack-no-prover`).",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(prover_jobs_completed_total[5m])",
          "legendFormat": "jobs/s",
          "refId": "A"
        }
      ]
    }
  ]
}
