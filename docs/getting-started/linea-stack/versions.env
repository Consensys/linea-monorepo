# =============================================================================
# Linea Stack — pinned image tags for the v0 standalone quickstart.
#
# Bump tags HERE only. This file is the single source of truth — do not
# hardcode tags in docker-compose.yml. Reviewed alongside upstream version
# bumps in the linea-monorepo (`docker/compose-spec-l2-services.yml` defaults).
#
# Last sync: 2026-05-06 — pulled from compose-spec-l2-services.yml,
#                         compose-spec-l1-services.yml, and
#                         compose-spec-extra-observability.yml defaults.
# =============================================================================

# ----- L2 EL (sequencer + l2-node-besu use the same image) ----------------------
# L1 = user-supplied Sepolia RPC; no local L1 services (Phase 1 Sepolia migration).
LINEA_BESU_PACKAGE_TAG=beta-v6-20260410083640-74d51b7

# ----- L2 core ------------------------------------------------------------------
LINEA_COORDINATOR_TAG=4ddbeba
LINEA_PROVER_TAG=4ddbeba
LINEA_POSTMAN_TAG=4ddbeba
LINEA_SHOMEI_TAG=3.2.3

# Maru (L2 consensus).
MARU_TAG=9737a45

# ----- Signing -------------------------------------------------------------------
WEB3SIGNER_TAG=26.3.0

# ----- Init / utility ------------------------------------------------------------
# busybox is used by the L2 genesis-init + config-render one-shots.
BUSYBOX_TAG=1.36.1

# Foundry image — used by the account-setup init container to derive deployer
# addresses from .env keys, query Sepolia for the L1 deployer's current nonce,
# and pre-compute deterministic CREATE addresses for every contract that will
# be deployed by deploy-contracts.sh. Pin to a specific build before any
# production-ish use (TODO Phase 5: lock to a release tag).
FOUNDRY_TAG=latest

# Node image used by the deploy-contracts one-shot
# (bind-mounts ../../../contracts and runs hardhat tasks).
NODE_IMAGE_TAG=24-bookworm

# ----- Storage -------------------------------------------------------------------
POSTGRES_TAG=17.6
# NOTE: Postgres 18+ changed its on-disk layout — the official image now expects
# the data directory at /var/lib/postgresql (not /var/lib/postgresql/data) so it
# can use major-version subdirs for pg_upgrade --link compatibility. Our compose
# mounts /var/lib/postgresql/data; PG 17 still accepts that path. Bump to 18+
# requires reworking every postgres service's volume mount.

# ----- L2 Explorer (default ON; L1 explorer = sepolia.etherscan.io) -------------
BLOCKSCOUT_TAG=7.0.2

# Observability stack (prometheus / loki / promtail / grafana) was dropped in
# Phase-7. Out of scope for v0 deliverable. Use `docker logs <service>` for
# per-container output; per-step deploy logs are in /shared/deploy-logs/ on
# the linea-shared-config volume.
