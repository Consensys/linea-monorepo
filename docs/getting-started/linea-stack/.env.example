# =============================================================================
# Linea Stack — user configuration.
#
# Copy this file to .env and fill in the REQUIRED values below before running:
#   docker compose --env-file versions.env --env-file .env --profile <profile> up -d
#
# The Sepolia deployer wallet is generated on first boot as an encrypted ethers
# keystore under artifacts/accounts/deployer-keystore/. Runtime transaction
# signer keys are generated separately. Do not commit .env or artifacts/.
# =============================================================================

# -----------------------------------------------------------------------------
# L1 mode. Sepolia is the default public-finality path. Local mode starts a
# quickstart-scoped Besu+Teku L1 and can leave L1_RPC_URL empty.
L1_MODE=sepolia

# -----------------------------------------------------------------------------
# REQUIRED — Sepolia L1 when L1_MODE=sepolia
# -----------------------------------------------------------------------------

# Sepolia HTTPS JSON-RPC endpoint. Infura / Alchemy / your own node — anything
# that accepts standard eth_* methods on Sepolia (chain ID 11155111).
# Examples:
#   https://sepolia.infura.io/v3/YOUR_PROJECT_ID
#   https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
L1_RPC_URL=

# On first Sepolia boot, ./scripts/start.sh --tail generates the encrypted
# deployer keystore, prints the deployer address and exact funding requirement,
# then exits before runtime containers are created. With host TypeScript
# dependencies installed, this happens before Docker pull/start; otherwise the
# same check runs inside Docker account setup. Fund that address on Sepolia and
# rerun the same command.
# Faucets: https://sepoliafaucet.com  https://www.alchemy.com/faucets/ethereum-sepolia

# For local mode:
# L1_MODE=local
# L1_RPC_URL=

# -----------------------------------------------------------------------------
# OPTIONAL — overrides
#
# The examples below stay commented so .env can remain small. For copy-paste
# recipe files, see:
#   profiles/ports.env.example
#   profiles/gas-sepolia.env.example
#   profiles/prover-partial.env.example
# Copy only the values you need into .env; docker compose and helper scripts
# still use .env as the single runtime config file.
# -----------------------------------------------------------------------------

# Data availability mode: ROLLUP only. Any other value fails at boot.
# LINEA_COORDINATOR_DATA_AVAILABILITY=ROLLUP

# Local L2 chain ID. Keep 1337 unless you are intentionally validating a
# different chain ID across genesis, prover public inputs, contracts, and
# explorer config. Changing this requires `docker compose down -v`.
# L2_CHAIN_ID=1337

# Forced transactions are outside the public quickstart path. Set true only if
# you intentionally want to deploy ForcedTransactionGateway for protocol testing.
# DEPLOY_FORCED_TRANSACTION_GATEWAY=false

# Postgres credentials (used by every isolated PG instance in the stack).
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# Host port mappings — uncomment + change if defaults collide on your machine.
# HOST_PORT_L2_SEQUENCER_RPC=8645
# HOST_PORT_MARU=8080
# HOST_PORT_L2_RPC=8745
# HOST_PORT_L2_WS=8746
# HOST_PORT_L2_ENGINE=8748
# HOST_PORT_SHOMEI=8998
# HOST_PORT_WEB3SIGNER=9000
# HOST_PORT_COORDINATOR_PG=5432
# HOST_PORT_POSTMAN_PG=5433
# HOST_PORT_BLOCKSCOUT_L2_PG=5435
# HOST_PORT_COORDINATOR=9545
# HOST_PORT_POSTMAN=9090
# HOST_PORT_L2_BLOCKSCOUT=4000
# HOST_PORT_L2_BLOCKSCOUT_FRONTEND=4001

# Funding thresholds for generated L1 runtime accounts. Defaults top up blob and
# finalization signers to 0.50 ETH each if below 0.40 ETH, and postman to
# 0.10 ETH if below 0.05 ETH. Uncomment only if you need to lower reserved ETH.
# L1_DEPLOYER_MIN_BALANCE_WEI=2000000000000000000
# L1_ROLE_MIN_BALANCE_WEI=400000000000000000
# L1_ROLE_TOP_UP_WEI=500000000000000000
# L1_POSTMAN_MIN_BALANCE_WEI=50000000000000000
# L1_POSTMAN_TOP_UP_WEI=100000000000000000

# Runtime keystore encryption for generated quickstart keys. The local/CI
# default is a committed dev password because Web3Signer rejects empty keystore
# passwords. Set one of these only if you want a custom password when the same
# Docker volume is reused. For Docker Compose, prefer LINETH_KEYSTORE_PASSWORD;
# password-file paths must be readable inside the account-setup container.
# LINETH_KEYSTORE_PASSWORD=
# LINETH_KEYSTORE_PASSWORD_FILE=

# Advanced L1 deployer override. Use an encrypted ethers keystore instead of
# the generated deployer if you already have a funded Sepolia deployer wallet.
# Relative paths resolve from this linea-stack directory.
# L1_DEPLOYER_KEYSTORE_PATH=artifacts/accounts/deployer-keystore/l1-deployer.json
# L1_DEPLOYER_KEYSTORE_PASSWORD=
# L1_DEPLOYER_KEYSTORE_PASSWORD_FILE=

# L1 contract deployment gas price. This is separate from the coordinator
# blob/finality caps below. Keep it comfortably above Sepolia base fee for demos.
# L1_DEPLOY_GAS_PRICE_WEI=5000000000

# L1 submission gas caps. Values are wei. Dynamic gas-price caps are disabled by
# default for quickstart reliability; the static caps below bound blob and
# finalization submissions. Set this to false only when intentionally debugging
# dynamic fee behavior.
# L1_DYNAMIC_GAS_PRICE_CAP_DISABLED=true
# L1_BLOB_MAX_FEE_PER_GAS_CAP_WEI=100000000000
# L1_BLOB_MAX_FEE_PER_BLOB_GAS_CAP_WEI=100000000000
# L1_BLOB_MAX_PRIORITY_FEE_PER_GAS_CAP_WEI=20000000000
# L1_FINALIZATION_MAX_FEE_PER_GAS_CAP_WEI=200000000000
# L1_FINALIZATION_MAX_PRIORITY_FEE_PER_GAS_CAP_WEI=40000000000

# Local L2 helper transaction gas price. The demo traffic and L2->L1 smoke
# scripts pin legacy local-L2 gas instead of letting the RPC auto-select an
# expensive EIP-1559 fee. Default is 0.1 gwei.
# L2_GAS_PRICE_WEI=100000000

# Prover mode. Default quickstart behavior is dev proofs so ordinary laptops
# can complete a boot. Set PROVER_DEV_OVERRIDE=false only for production-shaped
# partial proving, and raise Docker Desktop memory substantially first.
PROVER_DEV_OVERRIDE=true
# Required when PROVER_DEV_OVERRIDE=false. Keep this below Docker Desktop's
# memory limit so Besu/Shomei/coordinator still have room. For a 30-32GiB
# Docker allocation, start with 24GiB. For a 48GiB allocation, 32GiB is safer.
# PROVER_GOMEMLIMIT=24GiB
