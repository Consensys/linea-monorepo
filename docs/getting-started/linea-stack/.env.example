# =============================================================================
# Linea Stack — user configuration.
#
# Copy this file to .env and fill in the REQUIRED values below before running:
#   docker compose --env-file versions.env --env-file .env --profile <profile> up -d
#
# DEV ONLY for L2 — pre-baked dev keys are committed in config/. The L1 deployer
# key BELOW is YOURS and holds real Sepolia ETH. Do not commit your .env.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Sepolia L1
# -----------------------------------------------------------------------------

# Sepolia HTTPS JSON-RPC endpoint. Infura / Alchemy / your own node — anything
# that accepts standard eth_* methods on Sepolia (chain ID 11155111).
# Examples:
#   https://sepolia.infura.io/v3/YOUR_PROJECT_ID
#   https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
L1_RPC_URL=

# Hex-encoded private key (0x-prefixed) for the L1 deployer. Per Phase-1 of the
# Sepolia migration, this single key is used for ALL L1 operational roles
# (Option A): contract deployment, shnarf submission, finalization, postman
# L1 signer, message anchorer. The derived address MUST be Sepolia-funded.
# Faucets: https://sepoliafaucet.com  https://www.alchemy.com/faucets/ethereum-sepolia
L1_DEPLOYER_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL — overrides
# -----------------------------------------------------------------------------

# Data availability mode: ROLLUP (Sepolia blobs) or VALIDIUM (off-chain DA).
# LINEA_COORDINATOR_DATA_AVAILABILITY=ROLLUP

# Postgres credentials (used by every isolated PG instance in the stack).
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# Host port mappings — uncomment + change if defaults collide on your machine.
# HOST_PORT_L2_RPC=8745
# HOST_PORT_L2_WS=8746
# HOST_PORT_L2_BLOCKSCOUT=4000

# Prover mode. Default quickstart behavior is dev proofs so ordinary laptops
# can complete a boot. Set PROVER_DEV_OVERRIDE=false only for production-shaped
# partial proving, and raise Docker Desktop memory substantially first.
PROVER_DEV_OVERRIDE=true
# PROVER_GOMEMLIMIT=4GiB
