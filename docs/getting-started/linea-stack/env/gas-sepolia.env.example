# Optional Sepolia L1 gas and runtime signer funding knobs.
#
# Copy only the values you need into ../.env. Raising caps can spend more
# Sepolia ETH from the generated runtime signers.

# Funding thresholds for generated L1 runtime accounts.
L1_ROLE_MIN_BALANCE_WEI=100000000000000000
L1_ROLE_TOP_UP_WEI=150000000000000000
L1_POSTMAN_MIN_BALANCE_WEI=20000000000000000
L1_POSTMAN_TOP_UP_WEI=50000000000000000

# Dynamic gas-price caps. Keep dynamic caps enabled unless intentionally
# debugging fee behavior.
L1_DYNAMIC_GAS_PRICE_CAP_DISABLED=false
L1_BLOB_MAX_FEE_PER_GAS_CAP_WEI=100000000000
L1_BLOB_MAX_FEE_PER_BLOB_GAS_CAP_WEI=100000000000
L1_BLOB_MAX_PRIORITY_FEE_PER_GAS_CAP_WEI=20000000000
L1_FINALIZATION_MAX_FEE_PER_GAS_CAP_WEI=200000000000
L1_FINALIZATION_MAX_PRIORITY_FEE_PER_GAS_CAP_WEI=40000000000
