# =============================================================================
# Second stack instance: L2-only, attached to instance 1's local L1.
#
# Copy this file (e.g. to instances/i2.env) and run every quickstart script for
# this instance with LINETH_ENV_FILE pointing at it:
#
#   # instance 1 (owner) — plain local-L1 mode, unchanged:
#   #   .env contains L1_MODE=local
#   ./scripts/start.sh --tail
#
#   # instance 2 (attach) — after instance 1's L1 is up:
#   LINETH_ENV_FILE=instances/i2.env ./scripts/start.sh --tail
#   LINETH_ENV_FILE=instances/i2.env ./scripts/status.sh
#   LINETH_ENV_FILE=instances/i2.env ./scripts/reset.sh
#
# Every value below is instance identity — an instance 3 needs only another
# copy of this file with fresh names/ports/subnet/chain-id/deployer values.
# =============================================================================

# --- L1: reuse instance 1's local L1, do not start one -----------------------
L1_MODE=local
L1_LOCAL_ROLE=attach
# Docker network created by the L1-owning instance (<owner-project>_l1network).
# Only set this if instance 1 runs under a non-default COMPOSE_PROJECT_NAME.
# LINETH_L1_ATTACH_NETWORK=linea-stack_l1network
# Host-published L1 RPC port of the OWNER instance (used by host-side scripts).
HOST_PORT_L1_RPC=8445

# --- L1 deployer: distinct prefunded local-genesis dev account ---------------
# Each instance must deploy its own LineaRollup from its own L1 account so
# concurrent boots never contend on one account's nonce. These are committed
# DEV-ONLY keys from docker/config/l1-node/el/genesis.json ("account 1, can be
# used as end user"); instance 1 keeps the default genesis deployer account.
L1_LOCAL_DEPLOYER_PRIVATE_KEY=0x47e179ec197488593b187f80a00eb0da91f1b9d0b13f8733639f19c30a34926a
L1_LOCAL_DEPLOYER_ADDRESS=0x15d34AAf54267DB7D7c367839AAf71A00a2C6A65

# --- Instance identity -------------------------------------------------------
COMPOSE_PROJECT_NAME=linea-stack-i2
LINETH_CONTAINER_PREFIX=i2-
LINETH_ARTIFACTS_DIR=./artifacts-i2
L2_CHAIN_ID=1338

# Docker bridge subnets must not overlap between instances. The sequencer IP
# must sit inside this instance's L2 subnet (it is baked into the l2-node-besu
# bootnode enode URL).
L2_NETWORK_SUBNET=11.11.12.0/24
L2_SEQUENCER_IP=11.11.12.101
# Unused in attach role (no L1 services start) but kept non-overlapping so an
# accidental network creation cannot collide with the owner's L1 subnet.
L1_NETWORK_SUBNET=10.10.20.0/24
L1_EL_IP=10.10.20.201
L1_CL_IP=10.10.20.202

# --- Host ports (all distinct from instance 1's defaults) --------------------
HOST_PORT_L2_SEQUENCER_RPC=9645
HOST_PORT_MARU=9080
HOST_PORT_L2_RPC=9745
HOST_PORT_L2_WS=9746
HOST_PORT_L2_ENGINE=9748
HOST_PORT_SHOMEI=9998
HOST_PORT_WEB3SIGNER=10000
HOST_PORT_COORDINATOR_PG=6432
HOST_PORT_POSTMAN_PG=6433
HOST_PORT_BLOCKSCOUT_L2_PG=6435
HOST_PORT_COORDINATOR=10545
HOST_PORT_POSTMAN=10090
HOST_PORT_L2_BLOCKSCOUT=5100
HOST_PORT_L2_BLOCKSCOUT_FRONTEND=5101

# --- Prover ------------------------------------------------------------------
PROVER_DEV_OVERRIDE=true
