{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linea.build/schemas/getZkRollupProofV1.request.schema.json",
  "title": "getZkRollupProof V1 request",
  "description": "Coordinator -> prover rollup proof request. The shared, versioned contract for rollup_spec/proof_io_v1.py::decode_rollup_request. The example file getZkRollupProofV1.request.json uses '0x...' ellipsis placeholders for documentation and does NOT validate against this schema; real payloads must.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "proverVersion",
    "chainId",
    "blockRange",
    "blobs",
    "shnarfTransition",
    "l2ExecutionProofs"
  ],
  "properties": {
    "proverVersion": { "type": "string", "minLength": 1 },
    "chainId": { "$ref": "#/$defs/uint" },
    "blockRange": { "$ref": "#/$defs/blockRange" },
    "blobs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/blob" }
    },
    "shnarfTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parentShnarf", "endShnarf"],
      "properties": {
        "parentShnarf": { "$ref": "#/$defs/hash32" },
        "endShnarf": { "$ref": "#/$defs/hash32" }
      }
    },
    "l2ExecutionProofs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/l2ExecutionProof" }
    }
  },
  "$defs": {
    "uint": { "type": "integer", "minimum": 0 },
    "hex": { "type": "string", "pattern": "^0x([0-9a-fA-F]{2})*$" },
    "hash32": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "kzgProof": { "type": "string", "pattern": "^0x[0-9a-fA-F]{96}$" },
    "blockRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startBlockNumber", "endBlockNumber"],
      "properties": {
        "startBlockNumber": { "$ref": "#/$defs/uint" },
        "endBlockNumber": { "$ref": "#/$defs/uint" }
      }
    },
    "blob": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blobInputs", "blockRange", "blockRlps"],
      "properties": {
        "blobInputs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["blobHash", "blobKzgProof"],
          "properties": {
            "blobHash": { "$ref": "#/$defs/hash32" },
            "blobKzgProof": { "$ref": "#/$defs/kzgProof" }
          }
        },
        "blockRange": { "$ref": "#/$defs/blockRange" },
        "blockRlps": {
          "type": "array",
          "items": { "$ref": "#/$defs/hex" }
        }
      }
    },
    "l2ExecutionPublicInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parentBlockHash",
        "endBlockHash",
        "endBlockNumber",
        "endBlockTimestamp",
        "l2L1MessagesHash",
        "parentL1L2BridgeRollingHash",
        "parentL1L2BridgeRollingHashMessageNumber",
        "endL1L2BridgeRollingHash",
        "endL1L2BridgeRollingHashMessageNumber",
        "dynamicChainConfigHash",
        "parentFtxRollingHash",
        "endFtxRollingHash",
        "lastProcessedFtxNumber",
        "filteredAddressesHash",
        "txFromsHash"
      ],
      "properties": {
        "parentBlockHash": { "$ref": "#/$defs/hash32" },
        "endBlockHash": { "$ref": "#/$defs/hash32" },
        "endBlockNumber": { "$ref": "#/$defs/uint" },
        "endBlockTimestamp": { "$ref": "#/$defs/uint" },
        "l2L1MessagesHash": { "$ref": "#/$defs/hash32" },
        "parentL1L2BridgeRollingHash": { "$ref": "#/$defs/hash32" },
        "parentL1L2BridgeRollingHashMessageNumber": { "$ref": "#/$defs/uint" },
        "endL1L2BridgeRollingHash": { "$ref": "#/$defs/hash32" },
        "endL1L2BridgeRollingHashMessageNumber": { "$ref": "#/$defs/uint" },
        "dynamicChainConfigHash": { "$ref": "#/$defs/hash32" },
        "parentFtxRollingHash": { "$ref": "#/$defs/hash32" },
        "endFtxRollingHash": { "$ref": "#/$defs/hash32" },
        "lastProcessedFtxNumber": { "$ref": "#/$defs/uint" },
        "filteredAddressesHash": { "$ref": "#/$defs/hash32" },
        "txFromsHash": { "$ref": "#/$defs/hash32" }
      }
    },
    "l2ExecutionProof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proof",
        "startBlockNumber",
        "endBlockNumber",
        "publicInputs",
        "l2L1Messages",
        "txFroms",
        "filteredAddresses"
      ],
      "properties": {
        "proof": { "$ref": "#/$defs/hex" },
        "startBlockNumber": { "$ref": "#/$defs/uint" },
        "endBlockNumber": { "$ref": "#/$defs/uint" },
        "publicInputs": { "$ref": "#/$defs/l2ExecutionPublicInputs" },
        "l2L1Messages": { "type": "array", "items": { "$ref": "#/$defs/hash32" } },
        "txFroms": { "type": "array", "items": { "$ref": "#/$defs/address" } },
        "filteredAddresses": { "type": "array", "items": { "$ref": "#/$defs/address" } }
      }
    }
  }
}
