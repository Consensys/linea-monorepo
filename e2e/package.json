{
  "name": "e2e",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test:script": "npx jest --config ./jest.script.config.ts",
    "test:local:run": "TEST_ENV=local npx jest",
    "test:local": "pnpm run test:local:run --testPathIgnorePatterns=linea-besu-fleet.spec.ts --testPathIgnorePatterns=liveness.spec.ts && pnpm run test:liveness:local",
    "test:local-core": "pnpm run test:local:run --testPathIgnorePatterns=linea-besu-fleet.spec.ts --testPathIgnorePatterns=liveness.spec.ts --testPathIgnorePatterns=messaging.spec.ts --testPathIgnorePatterns=bridge-tokens.spec.ts --testPathIgnorePatterns=shomei-get-proof.spec.ts --testPathIgnorePatterns=transaction-exclusion.spec.ts",
    "test:fleet:local": "TEST_ENV=local npx jest linea-besu-fleet.spec.ts",
    "test:liveness:local": "TEST_ENV=local npx jest liveness.spec.ts",
    "test:sendbundle:local": "TEST_ENV=local npx jest send-bundle.spec.ts",
    "test:partial-prover:messaging:local": "TEST_ENV=local PARTIAL_PROVER=true npx jest messaging.spec.ts -t 'L1/L2 message txs for partial prover e2e testing'",
    "test:partial-prover:finalization:local": "TEST_ENV=local PARTIAL_PROVER=true npx jest submission-finalization.spec.ts -t 'Check latest L2 block number has been finalized on L1'",
    "test:partial-prover:local": "TEST_ENV=local npx jest opcodes.spec.ts l2.spec.ts eip7702.spec.ts && pnpm run test:partial-prover:messaging:local && pnpm run test:partial-prover:finalization:local",
    "test:dev": "TEST_ENV=dev npx jest --config ./jest.testnet.config.ts --bail --runInBand --testPathIgnorePatterns=linea-besu-fleet.spec.ts --testPathIgnorePatterns=liveness.spec.ts --testPathIgnorePatterns=restart.spec.ts",
    "test:sepolia": "TEST_ENV=sepolia npx jest --config ./jest.testnet.config.ts --bail --runInBand --testPathIgnorePatterns=linea-besu-fleet.spec.ts --testPathIgnorePatterns=liveness.spec.ts --testPathIgnorePatterns=restart.spec.ts",
    "postinstall": "npx ts-node ./scripts/generateAbi.ts",
    "clean": "rimraf node_modules src/generated",
    "generate-runtime-report": "tsx scripts/generate-e2e-runtime-report.ts"
  },
  "author": "",
  "license": "(MIT OR Apache-2.0)",
  "devDependencies": {
    "@consensys/eslint-config": "workspace:*",
    "@consensys/linea-shared-utils": "workspace:*",
    "@jest/globals": "catalog:",
    "@octokit/rest": "22.0.1",
    "@types/jest": "catalog:",
    "async-mutex": "0.5.0",
    "child_process": "1.0.2",
    "dotenv": "catalog:",
    "jest": "catalog:",
    "ts-jest": "catalog:",
    "tsx": "catalog:",
    "viem": "catalog:",
    "winston": "catalog:",
    "zod": "catalog:"
  }
}
