{
  "name": "contracts",
  "license": "(MIT OR Apache-2.0)",
  "type": "module",
  "imports": {
    "#hardhat-network-helpers": "./test/hardhat/common/helpers/hardhat-network-helpers.ts"
  },
  "engines": {
    "node": ">=24.14.1",
    "pnpm": ">=10.32.1"
  },
  "scripts": {
    "build": "hardhat build",
    "test": "pnpm run autoupdate && hardhat test",
    "test:reportgas": "hardhat test --gas-stats",
    "coverage": "pnpm run autoupdate && SOLIDITY_COVERAGE=true hardhat test --coverage",
    "autoupdate": "cd ../prover && cmd/dev-tools/testcase-gen/compression-aggregation/autoupdate.sh && cd ../contracts",
    "balance": "ts-node scripts/balanceOf.ts",
    "prettier:sol": "prettier -c '**/*.sol'",
    "prettier:sol:fix": "prettier -w '**/*.sol'",
    "lint:sol": "solhint -f stylish 'src/**/*.sol'",
    "lint:sol:fix": "solhint --fix --noPrompt -f stylish 'src/**/*.sol'",
    "lint:ts": "eslint '**/*.{js,ts}'",
    "lint:ts:fix": "eslint --fix '**/*.{js,ts}'",
    "lint": "pnpm run lint:sol && pnpm run lint:ts && pnpm run prettier:sol",
    "lint:fix": "pnpm run lint:sol:fix && pnpm run lint:ts:fix && pnpm run prettier:sol:fix",
    "validate:address-registry": "node --loader ts-node/esm --experimental-specifier-resolution=node scripts/deployment/validateAddressRegistry.ts",
    "validate:deploy-scripts": "node --loader ts-node/esm --experimental-specifier-resolution=node scripts/deployment/validateDeployScripts.ts",
    "clean": "rimraf .openzeppelin build cache node_modules typechain-types coverage coverage.json",
    "solidity:docgen": "echo 'Solidity docgen is not available during the Hardhat 3 migration; use Foundry docs until a Hardhat 3-compatible docgen is available.'"
  },
  "devDependencies": {
    "@chainlink/contracts": "1.5.0",
    "@chainsafe/blst": "2.2.0",
    "@chainsafe/persistent-merkle-tree": "1.2.5",
    "@consensys/eslint-config": "workspace:*",
    "@ethereumjs/util": "10.1.1",
    "@lidofinance/lsv-cli": "1.8.0",
    "@lodestar/types": "1.42.0",
    "@rocketh/node": "0.19.7",
    "@nomicfoundation/hardhat-ethers": "4.0.13",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "3.0.10",
    "@nomicfoundation/hardhat-foundry": "3.0.4",
    "@nomicfoundation/hardhat-mocha": "3.0.21",
    "@nomicfoundation/hardhat-network-helpers": "3.0.10",
    "@nomicfoundation/hardhat-typechain": "3.1.1",
    "@nomicfoundation/hardhat-verify": "3.0.19",
    "@openzeppelin/contracts": "4.9.6",
    "@openzeppelin/contracts-upgradeable": "4.9.6",
    "@openzeppelin/hardhat-upgrades": "4.0.1",
    "@typechain/ethers-v6": "catalog:",
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@types/yargs": "catalog:",
    "c-kzg": "4.1.0",
    "chai": "6.2.2",
    "colors": "1.4.0",
    "csv-parser": "3.2.0",
    "diff": "8.0.2",
    "dotenv": "catalog:",
    "ethers": "6.16.0",
    "forge-std": "github:foundry-rs/forge-std#1eea5bae12ae557d589f9f0f0edae2faa47cb262",
    "hardhat": "3.8.0",
    "hardhat-deploy": "2.0.8",
    "mocha": "11.7.6",
    "node-gyp": "12.3.0",
    "prettier": "catalog:",
    "prettier-plugin-solidity": "2.2.1",
    "solady": "0.1.26",
    "rocketh": "0.19.7",
    "solhint": "6.2.1",
    "yargs": "catalog:"
  }
}
