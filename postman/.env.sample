# Postman service configuration.
#
# The postman service is configured via a single JSON blob in the POSTMAN_CONFIG
# environment variable. The full shape is described by PostmanOptions in:
#   src/application/postman/app/config/config.ts
#
# --- SIGNER CONFIG -----------------------------------------------------------
#
# Each network's claiming block includes a "signer" field with one of two shapes:
#
# Private key signer (default, for development):
#   "signer": { "type": "private-key", "privateKey": "0x<hex>" }
#
# Web3Signer (for production environments):
#   "signer": {
#     "type": "web3signer",
#     "endpoint": "https://web3signer:9000",
#     "publicKey": "0x<hex>",
#     "tls": {                                   <- optional mTLS block
#       "keyStorePath":       "/certs/client.p12",
#       "keyStorePassword":   "<password>",
#       "trustStorePath":     "/certs/server.p12",
#       "trustStorePassword": "<password>"
#     }
#   }
#
# --- EXAMPLE POSTMAN_CONFIG --------------------------------------------------
#
# Replace all <placeholder> values before use.
# Only use the test private keys below for local development.

POSTMAN_CONFIG='{
  "l1Options": {
    "rpcUrl": "http://localhost:8445",
    "messageServiceContractAddress": "0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9",
    "isEOAEnabled": true,
    "isCalldataEnabled": true,
    "listener": {
      "pollingInterval": 2000,
      "blockConfirmation": 1,
      "maxBlocksToFetchLogs": 1000
    },
    "claiming": {
      "signer": { "type": "private-key", "privateKey": "0x8b3a350cf5c34c9194ca85829a2df0ec3153be0318b5e2d3348e872092edffba" },
      "messageSubmissionTimeout": 300000,
      "maxNonceDiff": 10000,
      "maxFeePerGasCap": "100000000000",
      "gasEstimationPercentile": 50,
      "isMaxGasFeeEnforced": false,
      "profitMargin": 0.01,
      "maxNumberOfRetries": 100,
      "retryDelayInSeconds": 30,
      "maxClaimGasLimit": "2560000",
      "maxTxRetries": 20,
      "isPostmanSponsorshipEnabled": true,
      "maxPostmanSponsorGasLimit": "250000"
    }
  },
  "l2Options": {
    "rpcUrl": "http://localhost:9045",
    "messageServiceContractAddress": "0xe537D669CA013d86EBeF1D64e40fC74CADC91987",
    "isEOAEnabled": true,
    "isCalldataEnabled": true,
    "l2MessageTreeDepth": 5,
    "enableLineaEstimateGas": false,
    "listener": {
      "pollingInterval": 2000,
      "blockConfirmation": 0,
      "maxBlocksToFetchLogs": 1000
    },
    "claiming": {
      "signer": { "type": "private-key", "privateKey": "0xfcf854e0a0bc6fd7e97d7050e61a362c915cecd6767a32267b22e8b7af572e58" },
      "messageSubmissionTimeout": 300000,
      "maxNonceDiff": 10000,
      "maxFeePerGasCap": "100000000000",
      "gasEstimationPercentile": 50,
      "isMaxGasFeeEnforced": false,
      "profitMargin": 0.01,
      "maxNumberOfRetries": 100,
      "retryDelayInSeconds": 30,
      "maxClaimGasLimit": "2560000",
      "maxTxRetries": 20,
      "isPostmanSponsorshipEnabled": false,
      "maxPostmanSponsorGasLimit": "250000"
    }
  },
  "l1L2AutoClaimEnabled": true,
  "l2L1AutoClaimEnabled": true,
  "databaseOptions": {
    "type": "postgres",
    "host": "127.0.0.1",
    "port": 5432,
    "username": "postgres",
    "password": "postgres",
    "database": "postman_db"
  },
  "databaseCleanerOptions": {
    "enabled": false,
    "cleaningInterval": 10000,
    "daysBeforeNowToDelete": 1
  },
  "apiOptions": {
    "port": 3000
  }
}'

# --- WEB3SIGNER EXAMPLE ------------------------------------------------------
#
# For production, replace each "signer" block above with:
#
#   "signer": {
#     "type": "web3signer",
#     "endpoint": "https://web3signer:9000",
#     "publicKey": "0x<your-public-key>",
#     "tls": {
#       "keyStorePath":       "/certs/client.p12",
#       "keyStorePassword":   "<keystore-password>",
#       "trustStorePath":     "/certs/server.p12",
#       "trustStorePassword": "<truststore-password>"
#     }
#   }
