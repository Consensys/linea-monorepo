L1_RPC_URL=http://localhost:8445
L1_CONTRACT_ADDRESS=0xDc64a140Aa3E981100a9becA4E685f962f0cF6C9
# Signer type: "private-key" or "web3signer"
L1_SIGNER_TYPE=private-key
# Only use the following PRIVATE KEY for testing
L1_SIGNER_PRIVATE_KEY=0x8b3a350cf5c34c9194ca85829a2df0ec3153be0318b5e2d3348e872092edffba
# Web3Signer options (used when L1_SIGNER_TYPE=web3signer)
# L1_WEB3_SIGNER_ENDPOINT=http://localhost:9000
# L1_WEB3_SIGNER_PUBLIC_KEY=0x...
# L1_WEB3_SIGNER_TLS_KEYSTORE_PATH=/path/to/keystore.p12
# L1_WEB3_SIGNER_TLS_KEYSTORE_PASSWORD=
# L1_WEB3_SIGNER_TLS_TRUSTSTORE_PATH=/path/to/truststore.p12
# L1_WEB3_SIGNER_TLS_TRUSTSTORE_PASSWORD=
# AWS KMS options (used when L1_SIGNER_TYPE=aws-kms); key must be ECC_SECG_P256K1 / SIGN_VERIFY
# AWS credentials are resolved via the standard AWS SDK credential chain (env vars, IRSA, instance role, etc.)
# L1_AWS_KMS_KEY_ID=alias/linea-postman-l1
# L1_AWS_KMS_REGION=eu-west-1
L1_LISTENER_INTERVAL=2000
L1_LISTENER_RECEIPT_POLLING_INTERVAL=1000
# L1_LISTENER_INITIAL_FROM_BLOCK=0
L1_LISTENER_BLOCK_CONFIRMATION=1
L1_MAX_BLOCKS_TO_FETCH_LOGS=1000
L1_MAX_GAS_FEE_ENFORCED=false
# L1_CLAIM_VIA_ADDRESS=0x...

L2_RPC_URL=http://localhost:9045
L2_CONTRACT_ADDRESS=0xe537D669CA013d86EBeF1D64e40fC74CADC91987
# Signer type: "private-key", "web3signer", or "aws-kms"
L2_SIGNER_TYPE=private-key
