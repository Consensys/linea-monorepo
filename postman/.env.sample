# Web3Signer options (used when L2_SIGNER_TYPE=web3signer)
# L2_WEB3_SIGNER_ENDPOINT=http://localhost:9000
# L2_WEB3_SIGNER_PUBLIC_KEY=0x...
# L2_WEB3_SIGNER_TLS_KEYSTORE_PATH=/path/to/keystore.p12
# L2_WEB3_SIGNER_TLS_KEYSTORE_PASSWORD=
# L2_WEB3_SIGNER_TLS_TRUSTSTORE_PATH=/path/to/truststore.p12
# L2_WEB3_SIGNER_TLS_TRUSTSTORE_PASSWORD=
# AWS KMS options (used when L2_SIGNER_TYPE=aws-kms); key must be ECC_SECG_P256K1 / SIGN_VERIFY
# AWS credentials are resolved via the standard AWS SDK credential chain (env vars, IRSA, instance role, etc.)
# L2_AWS_KMS_KEY_ID=alias/linea-postman-l2
# L2_AWS_KMS_REGION=eu-west-1
L2_LISTENER_INTERVAL=2000
L2_LISTENER_RECEIPT_POLLING_INTERVAL=1000
# L2_LISTENER_INITIAL_FROM_BLOCK=0
L2_LISTENER_BLOCK_CONFIRMATION=0
L2_MAX_BLOCKS_TO_FETCH_LOGS=1000
L2_MESSAGE_TREE_DEPTH=5
L2_MAX_GAS_FEE_ENFORCED=false
ENABLE_LINEA_ESTIMATE_GAS=false
# L2_CLAIM_VIA_ADDRESS=0x...

MESSAGE_SUBMISSION_TIMEOUT=300000
MAX_FETCH_MESSAGES_FROM_DB=1000
MAX_NONCE_DIFF=10000
MAX_FEE_PER_GAS_CAP=100000000000
GAS_ESTIMATION_PERCENTILE=50
PROFIT_MARGIN=0.01
MAX_NUMBER_OF_RETRIES=100
RETRY_DELAY_IN_SECONDS=30
MAX_CLAIM_GAS_LIMIT=2560000
MAX_BUMPS_PER_CYCLE=5
MAX_RETRY_CYCLES=10
L1_L2_EOA_ENABLED=true
L1_L2_CALLDATA_ENABLED=true
L1_L2_AUTO_CLAIM_ENABLED=true
L2_L1_EOA_ENABLED=true
L2_L1_CALLDATA_ENABLED=true
L2_L1_AUTO_CLAIM_ENABLED=true
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postman_db
# POSTGRES_SSL=false
# POSTGRES_SSL_REJECT_UNAUTHORIZED=false
# POSTGRES_SSL_CA_PATH=/path/to/ca.pem
DB_CLEANER_ENABLED=false
DB_CLEANING_INTERVAL=10000
DB_DAYS_BEFORE_NOW_TO_DELETE=1
LOG_LEVEL=info
API_PORT=3000
L1_L2_ENABLE_POSTMAN_SPONSORING=true
L2_L1_ENABLE_POSTMAN_SPONSORING=false
MAX_POSTMAN_SPONSOR_GAS_LIMIT=250000

# Optional event filter params
L1_EVENT_FILTER_FROM_ADDRESS=<FROM_ADDRESS>
