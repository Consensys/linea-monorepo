#!/usr/bin/env bash
#
# Pre-commit hook: prevent manual changes to the "besu" version field
# in gradle/libs.versions.toml. The "besu" version is auto-generated by
# "gradlew buildAndUpdateBesuVersionInLibsVersions" and should not be
# edited by hand.

FILE="gradle/libs.versions.toml"

# Check if the file is in the staged changes
if ! git diff --cached --name-only | grep -q "$FILE"; then
  exit 0
fi

# Check if the staged diff touches the "besu = " line
# We match lines like: +besu = "..." or -besu = "..."
if git diff --cached -- "$FILE" | grep -e '^[+-][[:space:]]*besu[[:space:]]*=.*"'; then
  echo ""
  echo "WARNING: You are trying to commit a change to the 'besu' version in $FILE."
  echo "This field is auto-generated by 'gradlew buildAndUpdateBesuVersionInLibsVersions'."
  echo "Please note this field will be updated and auto-committed by CI for PR contains 'besuCommit' change."
  echo "Reverting the 'besu' line change and continuing with the rest of your commit..."
  echo ""

  # Save the full staged content of the file
  # Then restore just the "besu = " line from HEAD
  git show HEAD:"$FILE" > /tmp/libs.versions.toml.orig 2>/dev/null

  if [ $? -eq 0 ]; then
    # Extract the original besu line
    ORIGINAL_BESU_LINE=$(grep -e '^besu\s*=' /tmp/libs.versions.toml.orig)

    if [ -n "$ORIGINAL_BESU_LINE" ]; then
      # Get the currently staged version of the file
      git show :"$FILE" > /tmp/libs.versions.toml.staged

      # Replace the besu line in the staged version with the original
      sed -i.bak "s/^[[:space:]]*besu[[:space:]]*=.*/$ORIGINAL_BESU_LINE/" /tmp/libs.versions.toml.staged

      # Update the git index with the fixed file (stage the corrected version)
      HASH=$(git hash-object -w /tmp/libs.versions.toml.staged)
      git update-index --cacheinfo 100644,"$HASH","$FILE"

      # Also revert the working tree copy
      sed -i.bak "s/^[[:space:]]*besu[[:space:]]*=.*/$ORIGINAL_BESU_LINE/" "$FILE"

      # Clean up
      rm -f "$FILE.bak" /tmp/libs.versions.toml.orig /tmp/libs.versions.toml.staged /tmp/libs.versions.toml.staged.bak

      echo "The 'besu' field has been reverted to: $ORIGINAL_BESU_LINE"
      echo "The rest of your changes to $FILE (if any) will still be committed."
      echo ""
    fi
  fi
fi

exit 0
