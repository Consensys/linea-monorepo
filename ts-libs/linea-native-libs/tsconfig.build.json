{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["./src/**/*.ts"],
  "exclude": ["./src/helpers/**/*", "./src/**/__tests__/**/*", "./src/**/*.test.ts"]
}
