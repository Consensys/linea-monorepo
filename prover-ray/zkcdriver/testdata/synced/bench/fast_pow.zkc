pub input data(address:u16) -> (word:u16)

// prove that two numbers add up to a third.
fn main() {
    var n:u16 = data[0]
    var k:u16 = data[1]
    var res:u32 = data[2] as u32

    if pow(n, k) != res {
        fail
    }
}

// compute n^k
fn pow(n:u16, k:u16) -> (res:u32) {
    var i:u16, acc:u32, b:u1
    //
    res = 1
    acc = n as u32
    i = k
    //
    while i != 0 {
        // divide by 2
        i::b = i as u17
        // check odd/even
        if b == 1 {
            res = res * acc
        }
        //
        acc = acc * acc
    }
}
