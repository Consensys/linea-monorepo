// Accepts: (x=0,y=0), (x=0,y=1), (x=1,y=anything)
// Rejects: (x=0,y>=2), (x>=2,y=anything)
fn main() {
    var x:u32 = data[0]
    var y:u32 = data[1]
    if x == 0 {
        if y == 0 {
        } else if y == 1 {
        } else {
            fail
        }
    } else if x == 1 {
    } else {
        fail
    }
}
