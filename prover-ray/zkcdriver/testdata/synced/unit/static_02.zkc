const BASE:u16 = 0x10

static rhs(address:u16) -> (byte:u16) {
    BASE,
    BASE + 1
}

pub input lhs(address:u16) -> (byte:u16)
pub input res(address:u16) -> (byte:u16)

// prove that lhs + rhs[0] equals res
fn main() {
    var lhs:u16 = lhs[0]
    var rhs:u16 = rhs[0]
    var res:u16 = res[0]

    if (lhs + rhs) != res {
        fail
    }

    return
}
