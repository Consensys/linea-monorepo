pub input data(address:u2) -> (byte:u8)

fn main() -> () {
    var cond:u8 = data[0]
    var valueTrue:u8 = data[1]
    var valueFalse:u8 = data[2]
    var result:u8 = data[3]

    var computedResult:u8
    computedResult = cond != 0 ? valueTrue:valueFalse

    if result != computedResult {
        fail
    }
}
