include "utils/constants.zkc"
include "ram/read.zkc"
include "ram/write.zkc"
include "interpreter.zkc"
include "utils/sign_extend.zkc"

pub input riscV_program(address:Address)->(Instruction:u32)
pub input riscV_program_length(rv:u1)->(length:Address)
pub input in_bytes(address:Address)->(bytes:u8)
pub input in_bytes_length(pi:u1)->(length:Address)
memory ram(address:Address)->(bytes:u8)
memory registers(id:Register)->(value:DoubleWord)

// TODO @Ghost
fn main<ram, registers>() {

var pc          : Address = ENTRY_POINT
var opcode      : Opcode
var instruction : Instruction
var stop_signal : u1 = 0

// copy public inputs and r5-program into the RAM
for i:Address=0; i<riscV_program_length[0]; i=i+1 {
    write_32((PROGRAM_OFFSET + (4*i)) as Address, riscV_program[i])
}
for j:Address=0; j<in_bytes_length[0]; j=j+1 {
    write_8((IN_BYTES_OFFSET + j) as Address, in_bytes[j])
}

while stop_signal == 0 {
      instruction = read_32(pc) as Instruction
      pc = interpreter(instruction, pc)
  }
}

